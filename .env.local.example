# ─── DATABASE ───────────────────────────────────────────
# Main xenoCampus platform DB (Render Postgres)
DATABASE_URL=postgresql://user:password@host:5432/xenocampus_main

# ─── STRIPE ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_GROWTH_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# ─── AUTH ────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this

# ─── APP ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
# Production: xenocampus.com

# ─── CLOUDFLARE R2 ───────────────────────────────────────
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=xenocampus-storage
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── EMAIL ───────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@xenocampus.com
